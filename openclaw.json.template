{
  "gateway": {
    "mode": "local"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "{{CUSTOMER_BOT_TOKEN}}",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "historyLimit": 100,
      "streaming": {
        "mode": "block"
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/opt/bintra/workspace",
      "model": {
        "primary": "{{CUSTOMER_LLM_MODEL_FQN}}"
      },
      "thinkingDefault": "low",
      "timeoutSeconds": 600,
      "bootstrapMaxChars": 24000,
      "bootstrapTotalMaxChars": 120000
    },
    "list": [
      {
        "id": "manager",
        "default": true,
        "workspace": "/opt/bintra/workspace",
        "skills": ["check_research_results", "deliver_research", "report_to_base"]
      }
    ]
  },
  "session": {
    "scope": "per-sender",
    "dmScope": "main",
    "reset": { "mode": "idle" },
    "store": "/opt/bintra/sessions/sessions.json"
  },
  "commands": {
    "text": true
  },
  "tools": {
    "profile": "coding",
    "deny": ["browser", "canvas"]
  }
}
